// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ユーザーモデル
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  bio       String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // リレーション
  works    Work[]
  projects Project[]
  contacts Contact[]

  @@map("users")
}

// 作品モデル
model Work {
  id          String   @id @default(uuid())
  title       String
  description String?
  imageUrl    String
  category    String
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // リレーション
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  projects Project[]

  @@map("works")
}

// プロジェクトモデル
model Project {
  id          String    @id @default(uuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // リレーション
  userId String
  user   User   @relation(fields: [userId], references: [id])
  works  Work[]

  @@map("projects")
}

// お問い合わせモデル
model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // リレーション
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("contacts")
}

// EC: 商品モデル
model Product {
  id              String    @id @default(uuid())
  slug            String    @unique
  // 多言語
  titleJa         String
  titleEn         String
  descriptionJa   String
  descriptionEn   String
  // 画像（Supabase Storage の URL 配列）
  imageUrls       String[]
  // 価格・在庫
  priceJpy        Int
  stockTotal      Int
  stockRemaining  Int
  // Stripe 連携
  stripeProductId String?
  stripePriceId   String?
  // 公開設定
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  // サイズ情報（バリエーションなしなので固定）
  sizeLabel       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // リレーション
  orderItems OrderItem[]

  @@map("products")
}

// EC: 注文ステータス
enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELED
  REFUNDED
}

// EC: 注文モデル
model Order {
  id                      String      @id @default(uuid())
  // Stripe 連携
  stripePaymentIntentId   String      @unique
  stripeCheckoutSessionId String?
  // 購入者情報
  customerEmail           String
  customerName            String?
  // 配送先（Stripe shipping から同期）
  shippingCountry         String
  shippingPostalCode      String?
  shippingCity            String?
  shippingLine1           String?
  shippingLine2           String?
  // 金額（円）
  subtotalJpy             Int
  shippingFeeJpy          Int
  totalJpy                Int
  // ステータス
  status                  OrderStatus @default(PENDING)
  // 購入時のロケール
  locale                  String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?
  shippedAt DateTime?

  // リレーション
  items OrderItem[]

  @@map("orders")
}

// EC: 注文明細（スナップショット保持）
model OrderItem {
  id            String @id @default(uuid())
  orderId       String
  productId     String
  titleSnapshot String
  priceSnapshot Int
  quantity      Int    @default(1)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}
