{
  "name": "yasu224",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "tsc": "tsgo --noEmit",
    "pre-commit-check": "npm run lint && npm run format && npm run tsc && npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npx http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.7.0",
    "@supabase/supabase-js": "^2.107.0",
    "next": "16.2.1",
    "prisma": "^7.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/nextjs-vite": "^10.4.0",
    "@storybook/test-runner": "^0.24.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.0",
    "http-server": "^14.1.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "postcss": "^8",
    "storybook": "^10.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@10.7.0"
}
